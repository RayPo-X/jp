const stripRuby = (text) => {
  if (typeof text !== 'string') return '';
  return text.replace(/\[[^\]]+\]/g, '');
};

const renderRuby = (text) => {
  if (typeof text !== 'string') return null;
  const parts = text.split(/([\u4e00-\u9faf]+\[[^\]]+\])/);
  return (
    <span className="inline-flex items-baseline">
      {parts.map((part, i) => {
        const match = part.match(/([\u4e00-\u9faf]+)\[([^\]]+)\]/);
        if (match) {
          return (
            <ruby key={i} className="mx-[1px]">
              {match[1]}
              <rt className="text-[0.6em] text-slate-500">{match[2]}</rt>
            </ruby>
          );
        }
        return <span key={i}>{part}</span>;
      })}
    </span>
  );
};

// 取得基礎錯誤解說
const getExplanation = (word, target) => {
  if (!word) return '';
  const jishoPlain = stripRuby(word.jisho);
  const endChar = jishoPlain.slice(-1);
  let rule = '';

  if (word.type === 'verb') {
    if (word.group === 1) {
      if (target === 'te' || target === 'ta') {
        const suffix = target === 'te' ? 'て' : 'た';
        const suffixDe = target === 'te' ? 'で' : 'だ';
        if (jishoPlain === '行く') return `「行く」是第一類動詞的例外，變化為促音便「行っ${suffix}」。`;
        if (['う', 'つ', 'る'].includes(endChar)) rule = `結尾是「${endChar}」，發生【促音便】，改為「っ${suffix}」`;
        else if (['む', 'ぶ', 'ぬ'].includes(endChar)) rule = `結尾是「${endChar}」，發生【撥音便】，改為「ん${suffixDe}」`;
        else if (endChar === 'く') rule = `結尾是「く」，發生【イ音便】，改為「い${suffix}」`;
        else if (endChar === 'ぐ') rule = `結尾是「ぐ」，發生【イ音便】，改為「い${suffixDe}」`;
        else if (endChar === 'す') rule = `結尾是「す」，改為「し${suffix}」`;
      } else if (target === 'nai' || target === 'nakatta') {
        const suffix = target === 'nai' ? 'ない' : 'なかった';
        if (endChar === 'う') rule = `結尾是「う」，改為「わ」加上${suffix}`;
        else rule = `將結尾「${endChar}」改成對應的「あ」段音，再加上${suffix}`;
      } else if (target === 'jisho') {
        rule = `從ます形推導：去掉ます，將「い」段音改為對應的「う」段音`;
      }
    } else if (word.group === 2) {
      if (target === 'jisho') rule = `去掉「ます」，直接加上「る」`;
      else rule = `第二類動詞最單純，直接去掉結尾的「る」(或ます)，加上「${target === 'te'?'て':target==='ta'?'た':target==='nai'?'ない':'なかった'}」即可`;
    } else if (word.group === 3) {
      rule = `第三類動詞（する、来る）為不規則變化，需要直接記憶喔！`;
    }
  } else if (word.type === 'adj_i') {
    if (jishoPlain === 'いい') rule = `「いい」是特殊い形容詞，變化時要用「よい」的字根去變。`;
    else if (target === 'te') rule = `い形容詞：去掉字尾的「い」，加上「くて」`;
    else if (target === 'ta') rule = `い形容詞：去掉字尾的「い」，加上「かった」`;
    else if (target === 'nai') rule = `い形容詞：去掉字尾的「い」，加上「くない」`;
    else if (target === 'nakatta') rule = `い形容詞：去掉字尾的「い」，加上「くなかった」`;
    else if (target === 'jisho') rule = `い形容詞：常體就是本身（去掉です）`;
  } else if (word.type === 'adj_na') {
    if (target === 'te') rule = `な形容詞：去掉「だ/です」，加上「で」`;
    else if (target === 'ta') rule = `な形容詞：常體的過去式，加上「だった」`;
    else if (target === 'nai') rule = `な形容詞：加上「じゃない」`;
    else if (target === 'nakatta') rule = `な形容詞：加上「じゃなかった」`;
    else if (target === 'jisho') rule = `な形容詞：常體為加上「だ」`;
  }
  return rule;
};

export default function App() {
  // --- APP 視圖狀態 ---
  const [appState, setAppState] = useState('home'); // 'home', 'playing'

  // --- 基礎設定 ---
  const [sourceForm, setSourceForm] = useState('masu'); 
  const [targetForms, setTargetForms] = useState(['te', 'ta', 'nai', 'jisho']); 
  const [activeWordTypes, setActiveWordTypes] = useState(['verb', 'adj_i', 'adj_na']);
  const [timeLimit, setTimeLimit] = useState(15); 
  const [inputMode, setInputMode] = useState('keyboard'); // 'keyboard' or 'choice'
  const [difficulty, setDifficulty] = useState('all'); // 'all', 'n5', 'n4'
  const [totalQuestionsPreset, setTotalQuestionsPreset] = useState(10);
  const [autoAdvance, setAutoAdvance] = useState(false); 

  // --- 進階功能狀態 ---
  const [showSettings, setShowSettings] = useState(false);
  const [activeSettingsTab, setActiveSettingsTab] = useState('general'); // general, scope, custom, mistakes, ranking, rpg, grammar
  const [testMode, setTestMode] = useState('normal'); // 'normal', 'custom', 'mistakes', 'rpg', 'grammar'
  
  const [mistakeBank, setMistakeBank] = useState({}); 
  const [customWordIds, setCustomWordIds] = useState([]); 
  const [statsBank, setStatsBank] = useState({}); 
  
  // --- 文法產生器狀態 ---
  const [customGrammars, setCustomGrammars] = useState(() => {
    try {
      const saved = localStorage.getItem('verbApp_customGrammars');
      return saved ? JSON.parse(saved) : DEFAULT_GRAMMARS;
    } catch {
      return DEFAULT_GRAMMARS;
    }
  });
  const [newGrammar, setNewGrammar] = useState({ name: '', baseForm: 'te', removeStr: '', appendStr: '', appliesTo: ['verb'] });

  useEffect(() => {
    localStorage.setItem('verbApp_customGrammars', JSON.stringify(customGrammars));
  }, [customGrammars]);

  // --- RPG 模式狀態 ---
  const [hp, setHp] = useState(3);
  const [rpgHighScore, setRpgHighScore] = useState(0);
  const [combo, setCombo] = useState(0);

  // --- 記憶功能 ---
  const [usedQuestionsHistory, setUsedQuestionsHistory] = useState([]); 

  // --- 回合與分數狀態 ---
  const [questionCount, setQuestionCount] = useState(1);
  const [score, setScore] = useState(0);
  const [isRoundComplete, setIsRoundComplete] = useState(false);
  const [roundHistory, setRoundHistory] = useState([]); 

  // --- 當前題目狀態 ---
  const [currentVerb, setCurrentVerb] = useState(null);
  const [currentTarget, setCurrentTarget] = useState('');
  const [currentGrammarDef, setCurrentGrammarDef] = useState(null); // 如果是文法題，儲存文法規則
  const [currentCorrectPlain, setCurrentCorrectPlain] = useState(''); // 正確答案純文字
  const [currentCorrectRuby, setCurrentCorrectRuby] = useState('');   // 正確答案帶注音格式
  
  const [userInput, setUserInput] = useState('');
  const [feedback, setFeedback] = useState(null); 
  const [explanation, setExplanation] = useState('');
  const [timeLeft, setTimeLeft] = useState(15);
  const [choiceOptions, setChoiceOptions] = useState([]);
  const [isPaused, setIsPaused] = useState(false);

  // 產生題目邏輯
  const generateQuestion = useCallback((overrideMode = null) => {
    const currentMode = overrideMode || testMode;
    let availablePool = [];
    const validTargets = targetForms.filter(form => form !== sourceForm);

    if (currentMode === 'grammar') {
      if (customGrammars.length === 0) {
        alert('您的自訂文法庫為空！請先至設定 > 自訂文法 中新增。');
        setTestMode('normal');
        return;
      }
      VERB_DB.forEach(word => {
        customGrammars.forEach(grammar => {
          if (grammar.appliesTo.includes(word.type)) {
            availablePool.push({ word, target: grammar.id, grammarDef: grammar, idKey: `${word.id}_${grammar.id}` });
          }
        });
      });
    }
    else if (currentMode === 'mistakes') {
      const mistakeKeys = Object.keys(mistakeBank);
      if (mistakeKeys.length === 0) {
        alert('錯題庫為空，將切換回一般模式。');
        setTestMode('normal');
        return;
      }
      availablePool = mistakeKeys.map(key => ({ word: mistakeBank[key].wordObj, target: mistakeBank[key].target, grammarDef: mistakeBank[key].grammarDef, idKey: key }));
    } 
    else if (currentMode === 'custom') {
      if (customWordIds.length === 0) return;
      const customWords = VERB_DB.filter(w => customWordIds.includes(w.id));
      customWords.forEach(word => {
        validTargets.forEach(target => availablePool.push({ word, target, grammarDef: null, idKey: `${word.id}_${target}` }));
      });
    }
    else {
      let filteredWords = VERB_DB.filter(w => activeWordTypes.includes(w.type));
      if (difficulty !== 'all') {
        filteredWords = filteredWords.filter(w => w.difficulty === difficulty);
      }
      if (filteredWords.length === 0) return;
      filteredWords.forEach(word => {
        validTargets.forEach(target => availablePool.push({ word, target, grammarDef: null, idKey: `${word.id}_${target}` }));
      });
    }

    if (availablePool.length === 0) return;

    // 防重複過濾
    const memorySize = totalQuestionsPreset * 3;
    let freshPool = availablePool.filter(item => !usedQuestionsHistory.includes(item.idKey));
    if (freshPool.length === 0) {
      freshPool = availablePool; 
      setUsedQuestionsHistory([]);
    }

    const selectedItem = freshPool[Math.floor(Math.random() * freshPool.length)];

    setUsedQuestionsHistory(prev => {
      const newHistory = [...prev, selectedItem.idKey];
      if (newHistory.length > memorySize) return newHistory.slice(newHistory.length - memorySize);
      return newHistory;
    });

    // 核心：設定題目與動態計算正確答案
    setCurrentVerb(selectedItem.word);
    setCurrentTarget(selectedItem.target);
    setCurrentGrammarDef(selectedItem.grammarDef || null);

    let finalCorrectRuby = '';
    let finalCorrectPlain = '';

    if (selectedItem.grammarDef) {
      // 套用自訂文法公式計算答案
      const rule = selectedItem.grammarDef;
      const baseRubyStr = selectedItem.word[rule.baseForm] || '';
      // 使用 Regex 去除指定的字尾 (如 'い')
      const replaceRegex = new RegExp((rule.removeStr || '') + '$');
      finalCorrectRuby = baseRubyStr.replace(replaceRegex, '') + rule.appendStr;
      finalCorrectPlain = stripRuby(finalCorrectRuby);
    } else {
      // 一般變化
      finalCorrectRuby = selectedItem.word[selectedItem.target];
      finalCorrectPlain = stripRuby(finalCorrectRuby);
    }

    setCurrentCorrectRuby(finalCorrectRuby);
    setCurrentCorrectPlain(finalCorrectPlain);

    setUserInput('');
    setFeedback(null);
    setExplanation('');
    setTimeLeft(timeLimit);
    setIsPaused(false);

    // 產生選擇題干擾選項
    if (inputMode === 'choice') {
      const optionsSet = new Set([finalCorrectPlain]);
      
      if (selectedItem.grammarDef) {
        // 文法模式下的干擾項：套用同樣規則在錯誤的基礎形上
        const wrongBases = ['masu', 'jisho', 'te', 'ta', 'nai'].filter(b => b !== selectedItem.grammarDef.baseForm);
        wrongBases.forEach(wb => {
          const wBaseRuby = selectedItem.word[wb];
          if(wBaseRuby) {
            const wAns = stripRuby(wBaseRuby).replace(new RegExp((selectedItem.grammarDef.removeStr||'') + '$'), '') + selectedItem.grammarDef.appendStr;
            optionsSet.add(wAns);
          }
        });
      } else {
        // 一般模式下的干擾項：替換錯誤的字尾
        const plain = stripRuby(selectedItem.word.jisho);
        const stem = plain.slice(0, -1);
        if (selectedItem.word.type === 'verb' && selectedItem.word.group === 1) {
          if (selectedItem.target === 'te') { optionsSet.add(stem+'いて'); optionsSet.add(stem+'んで'); optionsSet.add(stem+'って'); }
          if (selectedItem.target === 'ta') { optionsSet.add(stem+'いた'); optionsSet.add(stem+'んだ'); optionsSet.add(stem+'った'); }
          if (selectedItem.target === 'nai') { optionsSet.add(stem+'らない'); optionsSet.add(stem+'わない'); }
        } else if (selectedItem.word.type === 'adj_i') {
          const adjStem = plain.slice(0, -1);
          if (selectedItem.target === 'te') { optionsSet.add(adjStem+'で'); optionsSet.add(adjStem+'だ'); }
          if (selectedItem.target === 'ta') { optionsSet.add(adjStem+'だった'); optionsSet.add(adjStem+'た'); }
          if (selectedItem.target === 'nakatta') { optionsSet.add(adjStem+'じゃなかった'); }
        }
      }

      const resultOpts = Array.from(optionsSet);
      // 若不足 4 個選項，隨機抓取其他單字的相同目標答案
      while (resultOpts.length < 4) {
        const randWord = VERB_DB[Math.floor(Math.random() * VERB_DB.length)];
        let randAns = '';
        if (selectedItem.grammarDef) {
           const randBase = stripRuby(randWord[selectedItem.grammarDef.baseForm] || '');
           if(randBase) randAns = randBase.replace(new RegExp((selectedItem.grammarDef.removeStr||'') + '$'), '') + selectedItem.grammarDef.appendStr;
        } else {
           randAns = stripRuby(randWord[selectedItem.target] || '');
        }
        if (randAns && !resultOpts.includes(randAns)) resultOpts.push(randAns);
      }
      setChoiceOptions(resultOpts.slice(0, 4).sort(() => Math.random() - 0.5));
    }
  }, [sourceForm, targetForms, activeWordTypes, timeLimit, inputMode, difficulty, testMode, mistakeBank, customWordIds, usedQuestionsHistory, totalQuestionsPreset, customGrammars]);

  const startNewRound = useCallback((forcedMode = null) => {
    const modeToUse = forcedMode || testMode;
    if (forcedMode) setTestMode(forcedMode);
    
    setQuestionCount(1);
    setScore(0);
    setCombo(0);
    setRoundHistory([]); 
    setIsRoundComplete(false);
    setIsPaused(false);
    if (modeToUse === 'rpg') setHp(3);
    
    generateQuestion(modeToUse);
  }, [generateQuestion, testMode]);

  useEffect(() => {
    startNewRound();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  useEffect(() => {
    if (feedback !== null || isRoundComplete || timeLimit === 0 || !currentVerb || isPaused || appState === 'home') return;
    const timer = setInterval(() => {
      setTimeLeft(prev => {
        if (prev <= 1) {
          clearInterval(timer);
          return 0;
        }
        return prev - 1;
      });
    }, 1000);
    return () => clearInterval(timer);
  }, [feedback, isRoundComplete, timeLimit, currentVerb, isPaused, appState]); 

  useEffect(() => {
    if (timeLeft === 0 && feedback === null && currentVerb && !isPaused && appState === 'playing') {
      handleIncorrect(currentVerb, currentTarget, '[超時]', 'timeout');
    }
  }, [timeLeft, feedback, currentVerb, currentTarget, isPaused, appState]);

  const getTargetName = (id) => {
    const defaultOpt = FORM_OPTIONS.find(f => f.id === id);
    if (defaultOpt) return defaultOpt.label;
    const customOpt = customGrammars.find(g => g.id === id);
    if (customOpt) return customOpt.name;
    return id;
  };

  const recordStats = (word, target, isCorrect) => {
    const key = `${word.id}_${target}`;
    setStatsBank(prev => {
      const current = prev[key] || { attempts: 0, corrects: 0, wordObj: word, target: target };
      return {
        ...prev,
        [key]: {
          ...current,
          attempts: current.attempts + 1,
          corrects: current.corrects + (isCorrect ? 1 : 0)
        }
      };
    });
  };

  const handleIncorrect = (word, target, userAns, status) => {
    let exp = '';
    if (currentGrammarDef) {
       exp = `自訂文法【${currentGrammarDef.name}】變化規則：接續在【${getTargetName(currentGrammarDef.baseForm)}】後面。` +
             (currentGrammarDef.removeStr ? `去掉結尾「${currentGrammarDef.removeStr}」，` : '') +
             `加上「${currentGrammarDef.appendStr}」。`;
    } else {
       exp = getExplanation(word, target);
    }
    
    setFeedback(status);
    setExplanation(exp);
    setUserInput(userAns);
    recordStats(word, target, false);
    setCombo(0);

    if (testMode === 'rpg') setHp(prev => prev - 1);

    setMistakeBank(prev => ({
      ...prev,
      [`${word.id}_${target}`]: { wordObj: word, target: target, grammarDef: currentGrammarDef }
    }));

    setRoundHistory(prev => [...prev, {
      question: `請將「${stripRuby(word[sourceForm])}」轉換為【${getTargetName(target)}】：`,
      userAnswer: userAns,
      correctAnswer: currentCorrectPlain,
      userIsCorrect: false,
      explanation: exp
    }]);
  };

  const handleCorrect = (word, target, userAns) => {
    setFeedback('correct');
    setScore(prev => prev + 1);
    setCombo(prev => prev + 1);
    recordStats(word, target, true);

    if (testMode === 'rpg') setHp(prev => prev + 1);

    if (testMode === 'mistakes') {
      setMistakeBank(prev => {
        const newBank = { ...prev };
        delete newBank[`${word.id}_${target}`];
        return newBank;
      });
    }

    setRoundHistory(prev => [...prev, {
      question: `請將「${stripRuby(word[sourceForm])}」轉換為【${getTargetName(target)}】：`,
      userAnswer: userAns,
      correctAnswer: currentCorrectPlain,
      userIsCorrect: true
    }]);
  };

  const checkAnswer = (answerToCheck = null) => {
    if (feedback !== null) return;
    const finalAnswer = answerToCheck !== null ? answerToCheck : userInput;
    if (!finalAnswer.trim() && answerToCheck === null) return;

    const isCorrect = finalAnswer.trim() === currentCorrectPlain;

    if (isCorrect) handleCorrect(currentVerb, currentTarget, finalAnswer);
    else handleIncorrect(currentVerb, currentTarget, finalAnswer, 'incorrect');
  };

  const handleFormSubmit = (e) => {
    e.preventDefault();
    checkAnswer();
  };

  const nextQuestion = useCallback(() => {
    if (testMode === 'rpg') {
      if (hp <= 0) {
        setRpgHighScore(prev => Math.max(prev, score));
        setIsRoundComplete(true);
      } else {
        setQuestionCount(prev => prev + 1);
        generateQuestion();
      }
    } else {
      if (questionCount >= totalQuestionsPreset) {
        setIsRoundComplete(true);
      } else {
        setQuestionCount(prev => prev + 1);
        generateQuestion();
      }
    }
  }, [questionCount, totalQuestionsPreset, generateQuestion, testMode, hp, score]);

  useEffect(() => {
    if (autoAdvance && feedback === 'correct' && !isRoundComplete) {
      const timer = setTimeout(() => { nextQuestion(); }, 800);
      return () => clearTimeout(timer);
    }
  }, [feedback, autoAdvance, nextQuestion, isRoundComplete]);

  const handleAddGrammar = () => {
    if (!newGrammar.name || !newGrammar.appendStr) {
      alert('請填寫文法名稱與加上字尾！');
      return;
    }
    const newId = `g_custom_${Date.now()}`;
    setCustomGrammars(prev => [...prev, { ...newGrammar, id: newId }]);
    setNewGrammar({ name: '', baseForm: 'te', removeStr: '', appendStr: '', appliesTo: ['verb'] });
  };

  const handleDeleteGrammar = (id) => {
    if (window.confirm('確定要刪除這個自訂文法嗎？')) {
      setCustomGrammars(prev => prev.filter(g => g.id !== id));
    }
