                <Home className="w-5 h-5" /> 回首頁
              </button>
              <button onClick={() => setIsPaused(false)} className="px-8 py-3 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 transition-colors flex items-center justify-center gap-2">
                <Play className="w-5 h-5 fill-current" /> 繼續測驗
              </button>
            </div>
          </div>
        </div>
