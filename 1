            <div className="flex overflow-x-auto border-b border-slate-100 bg-slate-50 text-sm">
              <button onClick={() => setActiveSettingsTab('general')} className={`flex items-center gap-2 px-6 py-4 font-bold whitespace-nowrap transition-colors ${activeSettingsTab === 'general' ? 'bg-white text-blue-600 border-b-2 border-blue-600' : 'text-slate-500 hover:text-slate-800'}`}>基礎設定</button>
              <button onClick={() => setActiveSettingsTab('scope')} className={`flex items-center gap-2 px-6 py-4 font-bold whitespace-nowrap transition-colors ${activeSettingsTab === 'scope' ? 'bg-white text-blue-600 border-b-2 border-blue-600' : 'text-slate-500 hover:text-slate-800'}`}><Layers className="w-4 h-4"/> 範圍設定</button>
